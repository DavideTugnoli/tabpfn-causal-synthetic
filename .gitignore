external_baselines/**/results/final_*/**/__pycache__/
external_baselines/**/results/final_*/**/*.pyc

# Slurm job scripts and directories are cluster-specific, not for the repo
*.slurm
**/slurm/

# Only README / DEFAULTS / CONTRIBUTING markdown belongs in git
# (result tables and summaries live in the CSVs; working notes stay local)
*.md
!**/README.md
!**/DEFAULTS.md
!**/CONTRIBUTING.md

